# =============================================================================
# Pravah — Environment Variable Reference
# Copy this file to .env and fill in values for the services you want to use.
# Never commit your real .env file.
# =============================================================================

# ---------------------------------------------------------------------------
# Auth Backend
# ---------------------------------------------------------------------------
AUTH_PORT=4000
JWT_SECRET=change-me-in-production

# Paths to the local runtime data files used by the auth backend.
# These files are created automatically and are git-ignored.
# AUTH_USERS_FILE=flowconnect/auth-backend/users.local.json
# AUTH_WORKFLOWS_FILE=flowconnect/auth-backend/workflows.local.json
# AUTH_APPS_FILE=flowconnect/auth-backend/apps.local.json

# ---------------------------------------------------------------------------
# Frontend (Vite) — prefix all browser-visible vars with VITE_
# ---------------------------------------------------------------------------
VITE_AUTH_API_BASE_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Airtable
# ---------------------------------------------------------------------------
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_TABLE_NAME=

# ---------------------------------------------------------------------------
# Slack
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Discord
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
VITE_DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Typeform
# ---------------------------------------------------------------------------
TYPEFORM_TOKEN=

# ---------------------------------------------------------------------------
# Zoho CRM
# ---------------------------------------------------------------------------
ZOHO_ACCESS_TOKEN=
VITE_ZOHO_BRIDGE_URL=
VITE_ZOHO_MCP_URL=

# ---------------------------------------------------------------------------
# Razorpay
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Instamojo
# ---------------------------------------------------------------------------
INSTAMOJO_API_KEY=
INSTAMOJO_AUTH_TOKEN=
INSTAMOJO_BASE_URL=https://www.instamojo.com/api/1.1

# ---------------------------------------------------------------------------
# Fast2SMS
# ---------------------------------------------------------------------------
FAST2SMS_API_KEY=
VITE_FAST2SMS_API_KEY=

# ---------------------------------------------------------------------------
# Email (choose gmail or sendgrid)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=gmail

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Twilio (WhatsApp)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------------------------------------------------------------------------
# Anthropic (invoice-mcp AI features)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Google Forms / Google Service Account
# ---------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_FILE=

# ---------------------------------------------------------------------------
# Tally
# ---------------------------------------------------------------------------
TALLY_URL=http://localhost:9000
TALLY_TIMEOUT=5000
MOCK_MODE=false

# ---------------------------------------------------------------------------
# Invoice MCP server
# ---------------------------------------------------------------------------
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
COMPANY_NAME=Your Company
