# WhatsApp Bot & MCP Configuration

# 1. Meta WhatsApp Cloud API Setup Keys
# Generated in Meta Developer Dashboard -> App -> WhatsApp -> API Setup


# Where to get it: Dashboard -> API Setup.
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# Where to get it: Dashboard -> API Setup. This is a 15-digit number representing your specific phone number.
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Where to get it: Dashboard -> API Setup. This is a 15-digit ID representing your Business Account.
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Where to get it: You create this yourself!
# This is a secure, random password (e.g., my_super_secret_password). You must paste this exact string into the Meta Dashboard when configuring your Webhook.
WEBHOOK_VERIFY_TOKEN=your_secure_verify_token_here

# Port where your Express Webhook server will listen. Default is 3000.
PORT=3000

# The URL of your core FlowConnect engine where workflows are triggered.
FLOWCONNECT_WEBHOOK_URL=http://localhost:5000/api/webhooks/whatsapp

# Options: openai, claude, gemini, groq
DEFAULT_AI_PROVIDER=openai

# Fill out the API key only for the AI you plan to use:
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
